{
  "display_information": {
    "name": "Kept",
    "description": "Catches the promises your team makes to clients, and makes sure they're kept.",
    "background_color": "#16191b"
  },
  "features": {
    "bot_user": {
      "display_name": "Kept",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Track as promise",
        "type": "message",
        "callback_id": "track_message",
        "description": "Add this message to the Kept promise ledger"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "user": [
        "search:read.public",
        "search:read.private"
      ],
      "bot": [
        "assistant:write",
        "canvases:write",
        "chat:write",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im",
        "assistant_thread_started",
        "assistant_thread_context_changed"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}

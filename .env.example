# Copy this file to .env and fill in real values. .env is gitignored, never commit it.

# Bot token: Slack app settings -> Install App -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# App-level token: Slack app settings -> Basic Information -> App-Level Tokens
# create one with the connections:write scope for Socket Mode
SLACK_APP_TOKEN=xapp-...

# User token: Slack app settings -> Install App -> User OAuth Token
# only used for live recall search (Real-Time Search API)
SLACK_USER_TOKEN=xoxp-...

# Google Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
